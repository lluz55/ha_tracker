# Production defaults (loaded when APP_ENV=production)
APP_ENV=production
HA_URL=https://homeassistant.example.com
HA_TOKEN=replace_with_production_token
HA_DEVICE_ID=person.production_user
PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=5000
JWT_SECRET=replace_with_long_random_secret
ALLOW_REGISTRATION=false
