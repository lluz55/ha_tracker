# Home Assistant Configuration
# Your Home Assistant instance URL (including port, usually 8123)
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token (Create this in your HA Profile -> Security)
HA_TOKEN=your_long_lived_access_token_here

# Entity ID of the device/person to track (e.g., person.john or device_tracker.phone)
HA_DEVICE_ID=person.your_user

# Network Configuration
# Port for the Express/Go backend server (default: 3001)
BACKEND_PORT=3001

# Port for the Vite frontend development server (default: 5000)
FRONTEND_PORT=5000

# Authentication & Security
# Secret key used for signing JWT tokens
JWT_SECRET=super_secret_jwt_key_ha_tracker

# Allow new user (admin) registrations (true/false)
ALLOW_REGISTRATION=true
